{
  "name": "@pureskillgg/awsjs",
  "version": "3.0.1",
  "description": "Clients and tools for building on AWS.",
  "type": "module",
  "main": "index.js",
  "exports": {
    "import": "./index.js",
    "default": "./index.js"
  },
  "module": "index.js",
  "sideEffects": false,
  "keywords": [
    "node"
  ],
  "homepage": "https://github.com/pureskillgg/awsjs",
  "bugs": "https://github.com/pureskillgg/awsjs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pureskillgg/awsjs.git"
  },
  "license": "MIT",
  "author": {
    "name": "PureSkill.gg",
    "email": "contact@pureskill.gg"
  },
  "files": [
    "package-lock.json",
    "index.js",
    "lib",
    "data",
    "docs"
  ],
  "scripts": {
    "test": "c8 ava",
    "pretest": "node index.js",
    "test:update": "ava --update-snapshots",
    "test:watch": "ava --watch",
    "test:debug": "ava debug --break",
    "lint": "npm-run-all --parallel lint:*",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check --ignore-path .gitignore '**/*.{js,cjs,mjs,json,yml,yaml,graphql}'",
    "lint:docs": "documentation lint 'lib/**/*.doc.js'",
    "prepublishOnly": "npm-run-all --parallel lint test",
    "preversion": "npm-run-all --parallel lint test",
    "postversion": "git push --follow-tags",
    "example": "node examples",
    "example:inspect": "node --inspect examples",
    "format": "npm-run-all --parallel format:*",
    "preformat": "prettier --write --ignore-path .gitignore '**/*.{js,cjs,mjs,json,yml,yaml,graphql}'",
    "format:js": "eslint --fix .",
    "docs": "documentation serve --watch --github 'lib/**/*.doc.js'",
    "docs:build": "documentation build --format html --github --output .docs 'lib/**/*.doc.js'",
    "report": "c8 report"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.20.0",
    "@aws-sdk/client-eventbridge": "^3.20.0",
    "@aws-sdk/client-lambda": "^3.20.0",
    "@aws-sdk/client-s3": "^3.20.0",
    "@aws-sdk/client-scheduler": "^3.20.0",
    "@aws-sdk/client-sqs": "^3.20.0",
    "@aws-sdk/lib-dynamodb": "^3.20.0",
    "@aws-sdk/util-dynamodb": "^3.20.0",
    "@pureskillgg/mlabs-logger": "^10.0.0",
    "@pureskillgg/phi": "^6.0.0",
    "@pureskillgg/tau": "^4.0.0",
    "change-case": "^5.4.4",
    "get-stream": "^9.0.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@pureskillgg/examplr": "^8.0.1",
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "documentation": "^14.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "neostandard": "^0.13.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "testdouble": "^3.20.2"
  }
}
